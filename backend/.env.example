OPENAI_API_KEY=
GEMINI_API_KEY=

# Phase 3 — Embedding Provider Architecture
# Supported values: sentence-transformers | openai | gemini
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Phase 3 — Module 2: ChromaDB Vector Storage
# Directory (relative to backend/) where ChromaDB persists its data
CHROMA_PERSIST_DIR=data/chroma
# Number of semantic search results returned by /kb/search
SEARCH_N_RESULTS=5
